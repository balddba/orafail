#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -x "${SCRIPT_DIR}/.venv/bin/python" ]]; then
  exec "${SCRIPT_DIR}/.venv/bin/python" "${SCRIPT_DIR}/oraacle_loging_failure_monitor.py" "$@"
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 "${SCRIPT_DIR}/oraacle_loging_failure_monitor.py" "$@"
fi

echo "Error: python3 not found and .venv/bin/python is unavailable." >&2
exit 1
